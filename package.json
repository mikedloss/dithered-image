{
  "name": "dithered-image-monorepo",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:lib": "turbo build --filter=@dloss/dithered-image",
    "lint": "turbo lint",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/dist .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "turbo": "^2.8.20",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
