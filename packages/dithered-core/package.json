{
  "name": "@dloss/dithered-core",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Core dithering engine - Canvas 2D dot renderer with physics-based interactions",
  "homepage": "https://dithered-image-docs.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikedloss/dither",
    "directory": "packages/dithered-core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.21.5"
  },
  "keywords": [
    "dither",
    "canvas",
    "dots",
    "stipple",
    "engine"
  ],
  "publishConfig": {
    "access": "public"
  }
}
